#!/bin/sh
# qcom-tests — on-board Qualcomm bring-up validation runner.
#
# Run with no arguments and pick the test(s) from the interactive menu.
# Reports PASS/FAIL per selected step, exiting non-zero if any fail:
#   1) ADSP  FastRPC  — fastrpc_test -d 0 -U 0  (OP-TEE PAS bring-up of aDSP)
#   2) CDSP  FastRPC  — fastrpc_test -d 3 -U 0  (OP-TEE PAS bring-up of cDSP)
#   3) VIDEO round-trip — encode→decode in one pipeline (iris/venus codec)
#   4) CPU stress     — saturate every core for STRESS_SECS (soak/thermal test)
#
# Env: FRAMES (encode frame count, default 100).
#      STRESS_SECS (CPU stress duration in seconds, default 7200 = 2h).

FRAMES="${FRAMES:-100}"
STRESS_SECS="${STRESS_SECS:-7200}"

pass=0
fail=0

run() {
	name="$1"
	shift
	echo "           "
	echo "=================================================================="
	echo "[ RUN  ] $name"
	echo "         $*"
	if "$@"; then
		echo "[ PASS ] $name"
		pass=$((pass + 1))
	else
		rc=$?
		echo "[ FAIL ] $name (exit $rc)"
		fail=$((fail + 1))
	fi
}

test_adsp() {
	fastrpc_test -d 0 -U 0
}

test_cdsp() {
	fastrpc_test -d 3 -U 0
}

# Encode then decode in a single pipeline (no intermediate file) — exercises the
# iris codec end-to-end in one pass. Bounded by FRAMES so it reaches EOS.
test_roundtrip() {
	gst-launch-1.0 -e videotestsrc num-buffers="$FRAMES" pattern=smpte ! \
		videoconvert ! video/x-raw,format=NV12,width=1280,height=720,framerate=30/1 ! \
		v4l2h264enc ! h264parse ! v4l2h264dec ! fakesink sync=false
}

# Print a one-line health snapshot: elapsed/total, 1-min load, and every
# thermal-zone temperature in degrees C. Lets you watch for throttling or a
# climbing temperature during a long soak.
stress_heartbeat() {
	elapsed="$1"
	load=$(cut -d' ' -f1 /proc/loadavg 2>/dev/null)
	temps=
	for tz in /sys/class/thermal/thermal_zone*/temp; do
		[ -r "$tz" ] || continue
		t=$(cat "$tz" 2>/dev/null)
		[ -n "$t" ] || continue
		# Kernel reports millidegrees; show whole degrees C.
		temps="$temps $((t / 1000))C"
	done
	echo "[stress] ${elapsed}s/${STRESS_SECS}s  load:${load:-?}  temps:${temps:- n/a}"
}

# CPU soak test: saturate every online core for STRESS_SECS. Prefers stress-ng
# when present; otherwise falls back to one busybox 'yes' busy-loop per core.
# Either way a heartbeat prints load + thermal-zone temps every 60s so a thermal
# shutdown or core dying is visible. Returns non-zero if a worker dies early or
# stress-ng reports failure.
test_stress() {
	ncpu=$(nproc 2>/dev/null || echo 1)
	echo "[stress] saturating $ncpu core(s) for ${STRESS_SECS}s"

	if command -v stress-ng >/dev/null 2>&1; then
		echo "[stress] using stress-ng --cpu $ncpu"
		# --tz prints thermal-zone temps in the final metrics; --metrics gives a
		# per-stressor summary. stress-ng exits non-zero on any worker failure.
		stress-ng --cpu "$ncpu" --timeout "${STRESS_SECS}s" \
			--tz --metrics --times &
		stpid=$!
	else
		echo "[stress] stress-ng not found — using busybox 'yes' busy-loops"
		pids=
		i=0
		while [ "$i" -lt "$ncpu" ]; do
			yes >/dev/null 2>&1 &
			pids="$pids $!"
			i=$((i + 1))
		done
		stpid=
	fi

	# Heartbeat loop until the deadline. Bail early if a worker dies.
	t=0
	rc=0
	while [ "$t" -lt "$STRESS_SECS" ]; do
		sleep 60
		t=$((t + 60))
		[ "$t" -gt "$STRESS_SECS" ] && t="$STRESS_SECS"
		stress_heartbeat "$t"

		if [ -n "$stpid" ]; then
			# stress-ng path: stop early if it exited before the deadline.
			kill -0 "$stpid" 2>/dev/null || break
		else
			# busybox path: every worker must still be alive.
			for p in $pids; do
				if ! kill -0 "$p" 2>/dev/null; then
					echo "[stress] worker $p died early — possible instability" >&2
					rc=1
					break
				fi
			done
			[ "$rc" -ne 0 ] && break
		fi
	done

	# Reap workers and collect the final status.
	if [ -n "$stpid" ]; then
		wait "$stpid"
		rc=$?
	else
		for p in $pids; do kill "$p" 2>/dev/null; done
		for p in $pids; do wait "$p" 2>/dev/null; done
	fi

	echo "[stress] finished after ${t}s"
	return "$rc"
}

sel_1=0
sel_2=0
sel_3=0
sel_4=0

prompt_selection() {
	echo "Select tests to run:"
	echo "  1) ADSP  FastRPC  (-d 0 -U 0)"
	echo "  2) CDSP  FastRPC  (-d 3 -U 0)"
	echo "  3) VIDEO round-trip (encode->decode)"
	echo "  4) CPU stress (${STRESS_SECS}s soak/thermal)"
	echo "  a) all            q) quit"
	printf "Choice> "
	read -r sel || exit 0
}

# Parse a whitespace/comma-separated selection (e.g. "1 3" or "a"). Blank = all.
parse_selection() {
	s=$(printf '%s' "$1" | tr ',' ' ')
	[ -z "$(printf '%s' "$s" | tr -d ' ')" ] && s=a
	for tok in $s; do
		case "$tok" in
			1) sel_1=1 ;;
			2) sel_2=1 ;;
			3) sel_3=1 ;;
			4) sel_4=1 ;;
			a | A | all | ALL) sel_1=1; sel_2=1; sel_3=1; sel_4=1 ;;
			q | Q | quit) exit 0 ;;
			*) echo "qcom-tests: ignoring unknown choice '$tok'" >&2 ;;
		esac
	done
}

prompt_selection
parse_selection "$sel"

if [ $((sel_1 + sel_2 + sel_3 + sel_4)) -eq 0 ]; then
	echo "qcom-tests: no valid tests selected" >&2
	exit 1
fi

[ "$sel_1" -eq 1 ] && run "1) ADSP  FastRPC  (-d 0 -U 0)" test_adsp
[ "$sel_2" -eq 1 ] && run "2) CDSP  FastRPC  (-d 3 -U 0)" test_cdsp
[ "$sel_3" -eq 1 ] && run "3) VIDEO round-trip (encode->decode)" test_roundtrip
[ "$sel_4" -eq 1 ] && run "4) CPU stress (${STRESS_SECS}s soak)" test_stress

echo "=================================================================="
echo "qcom-tests: $pass passed, $fail failed"
[ "$fail" -eq 0 ]
